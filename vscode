#!/bin/bash

# ==============================================================================
#  VS CODE FOR TERMUX - ULTIMATE EDITION
#  Author: Mahesh Technicals
# ==============================================================================

# --- 1. DEFINING COLORS & STYLES ---
RESET="\033[0m"
BOLD="\033[1m"

# Gradient-like Palette (Simulated)
C1="\033[38;5;196m" # Red
C2="\033[38;5;202m" # Orange
C3="\033[38;5;220m" # Yellow
C4="\033[38;5;46m"  # Green
C5="\033[38;5;51m"  # Cyan
C6="\033[38;5;21m"  # Blue
C7="\033[38;5;201m" # Purple
C8="\033[38;5;255m" # White

# Status Colors
SUCCESS="${BOLD}${C4}"
ERROR="${BOLD}${C1}"
INFO="${BOLD}${C5}"
WARN="${BOLD}${C3}"
HEADER_TXT="${BOLD}${C8}"

# --- 2. HEADER FUNCTION ---
draw_header() {
    clear
    echo -e "${C6}======================================================${RESET}"
    echo -e "${C5}    🚀  V S   C O D E   F O R   T E R M U X  🚀   ${RESET}"
    echo -e "${C6}======================================================${RESET}"
    echo -e "${C7}         ✨  Created by Mahesh Technicals  ✨       ${RESET}"
    echo -e "${C6}======================================================${RESET}"
    echo ""
}

# --- 3. ARCHITECTURE CHECK ---
if [ "$(dpkg --print-architecture)" != "arm64" ]; then
    echo -e "${ERROR}❌ FATAL ERROR: This script is only for arm64 (Termux/Android).${RESET}"
    exit 1
fi

draw_header
echo -e "${BOLD}Choose an action:${RESET}"
echo -e "${C4}[1]${RESET} 📦 Install / Update VS Code ${C2}(Safe Mode)${RESET}"
echo -e "${C1}[2]${RESET} 🗑️  Uninstall VS Code Completely"
echo -e "${C6}------------------------------------------------------${RESET}"
read -p "👉 Enter your choice [1 or 2]: " choice

# ==========================================================
# FUNCTION: INSTALL / UPDATE
# ==========================================================
install_vscode() {
    draw_header
    
    # --- STEP 0: CHECK CURRENT VERSION ---
    echo -e "${INFO}🔍 Checking current status...${RESET}"
    if command -v code &> /dev/null; then
        OLD_VER=$(code --no-sandbox --disable-gpu --version 2>/dev/null | head -n 1)
        echo -e "   ➡️  Current Version: ${C3}$OLD_VER${RESET}"
    else
        OLD_VER="None"
        echo -e "   ➡️  Current Version: ${C2}Not Installed${RESET}"
    fi

    echo -e "\n${INFO}⬇️  Starting Download...${RESET}"

    # 1. Download
    rm -f vscode_latest.deb
    # Using wget with -q --show-progress for a cleaner bar
    wget -q --show-progress "https://code.visualstudio.com/sha/download?build=stable&os=linux-deb-arm64" -O vscode_latest.deb

    if [ ! -s vscode_latest.deb ]; then
        echo -e "${ERROR}❌ ERROR: Download failed. Check internet connection.${RESET}"
        exit 1
    fi

    # 2. Extract
    echo -e "\n${INFO}📦 Extracting files...${RESET}"
    rm -rf vscode_temp
    mkdir -p vscode_temp
    cd vscode_temp
    ar x ../vscode_latest.deb
    tar -xf data.tar.xz 2>/dev/null || tar -xf data.tar.gz

    # 3. Install
    echo -e "${INFO}📂 Installing to system...${RESET}"
    if [ -d usr ]; then
        sudo cp -rf usr/* /usr/
        sudo chmod -R 755 /usr/share/code
        echo -e "${SUCCESS}   ✅ Files copied successfully.${RESET}"
        
        echo -e "${INFO}🔗 Linking command...${RESET}"
        sudo ln -sf /usr/share/code/bin/code /usr/bin/code
    else
        echo -e "${ERROR}❌ ERROR: Extraction failed.${RESET}"
        cd ..
        rm -rf vscode_temp vscode_latest.deb
        exit 1
    fi

    # 4. Cleanup
    cd ..
    rm -rf vscode_temp vscode_latest.deb

    # 5. Patch Shortcut
    DESKTOP_FILE="/usr/share/applications/code.desktop"
    if [ -f "$DESKTOP_FILE" ]; then
        echo -e "${INFO}🔧 Patching Desktop Shortcut...${RESET}"
        sudo sed -i 's|^Exec=/usr/share/code/code|Exec=/usr/share/code/code --no-sandbox --disable-gpu --password-store="basic"|g' "$DESKTOP_FILE"
        echo -e "${SUCCESS}   ✅ Keyring & GPU crash fixed.${RESET}"
    fi

    # 6. SMART SETTINGS CHECK
    echo -e "\n${INFO}⚙️  Configuring User Settings...${RESET}"
    SETTINGS_FILE="$HOME/.config/Code/User/settings.json"
    mkdir -p "$HOME/.config/Code/User"

    if [ -f "$SETTINGS_FILE" ]; then
        echo -e "${WARN}   ⚠️  Existing settings found. Preserving your config.${RESET}"
    else
        echo -e "${SUCCESS}   ✅ Creating optimized defaults for Termux...${RESET}"
        cat <<EOF > "$SETTINGS_FILE"
{
    "extensions.verifySignature": false,
    "settingsSync.keychain": false,
    "security.workspace.trust.enabled": false,
    "telemetry.telemetryLevel": "off",
    "update.mode": "manual",
    "window.titleBarStyle": "custom"
}
EOF
    fi

    # --- STEP 7: SUMMARY ---
    NEW_VER=$(code --no-sandbox --disable-gpu --version 2>/dev/null | head -n 1)

    echo -e "\n${C6}======================================================${RESET}"
    echo -e "${C4}           🎉  INSTALLATION COMPLETE  🎉            ${RESET}"
    echo -e "${C6}======================================================${RESET}"
    echo -e "   📂 Old Version : ${C1}$OLD_VER${RESET}"
    echo -e "   📂 New Version : ${C4}$NEW_VER${RESET}"
    echo -e "${C6}======================================================${RESET}"

    if [ "$OLD_VER" == "$NEW_VER" ]; then
        echo -e "${INFO}   ℹ️  You are already up to date!${RESET}"
    else
        echo -e "${SUCCESS}   🚀 Update Successful!${RESET}"
    fi
    echo ""
}

# ==========================================================
# FUNCTION: UNINSTALL
# ==========================================================
uninstall_vscode() {
    echo -e "\n${C1}======================================================${RESET}"
    echo -e "${C1}             ⚠️   UNINSTALL WARNING   ⚠️              ${RESET}"
    echo -e "${C1}======================================================${RESET}"
    echo -e "This will delete VS Code and ALL extensions/data."
    read -p "👉 Are you sure you want to proceed? (y/n): " confirm
    
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then 
        echo -e "${SUCCESS}🚫 Cancelled.${RESET}"
        exit 0
    fi

    echo -e "\n${INFO}🧹 Cleaning up...${RESET}"
    
    sudo dpkg --remove --force-all code 2>/dev/null
    echo -e "   🗑️  Removed Package Entry"
    
    sudo rm -rf /usr/share/code /usr/bin/code
    echo -e "   🗑️  Deleted Application Files"
    
    sudo rm -f /usr/share/applications/code.desktop ~/Desktop/code.desktop
    echo -e "   🗑️  Removed Shortcuts"
    
    rm -rf ~/.vscode ~/.config/Code
    echo -e "   🗑️  Wiped User Data"
    
    sudo apt autoremove -y >/dev/null

    echo -e "\n${SUCCESS}✅ VS Code has been completely removed.${RESET}"
}

# ==========================================================
# MAIN LOGIC
# ==========================================================
case "$choice" in
    1) install_vscode ;;
    2) uninstall_vscode ;;
    *) echo -e "${ERROR}❌ Invalid choice. Exiting.${RESET}"; exit 1 ;;
esac
